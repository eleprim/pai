{
  "entities": {
    "Account": {
      "title": "Account",
      "description": "A ledger account in the Chart of Accounts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "category": { "type": "string", "enum": ["Asset", "Liability", "Equity", "Revenue", "Expense"] },
        "cashFlowCategory": { "type": "string", "enum": ["Operating", "Investing", "Financing", "None"] },
        "subcategory": { "type": "string" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["name", "code", "category"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "A financial transaction record consisting of balanced debits and credits.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "reference": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Posted"] },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "totalDebit": { "type": "number" },
        "totalCredit": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["date", "description", "status", "totalDebit", "totalCredit"]
    },
    "TransactionLine": {
      "title": "Transaction Line",
      "description": "An individual line item within a journal entry.",
      "type": "object",
      "properties": {
        "entryId": { "type": "string" },
        "accountId": { "type": "string" },
        "debit": { "type": "number" },
        "credit": { "type": "number" },
        "memo": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["entryId", "accountId", "debit", "credit", "date", "createdBy"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application configuration and organization details.",
      "type": "object",
      "properties": {
        "orgName": { "type": "string" },
        "currency": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["orgName", "currency"]
    }
  },
  "firestore": {
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Chart of Accounts"
    },
    "/journalEntries/{entryId}": {
      "schema": "JournalEntry",
      "description": "List of journal entries"
    },
    "/transactions/{transactionId}": {
      "schema": "TransactionLine",
      "description": "Individual debit/credit lines for aggregation"
    },
    "/settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Application settings (usually just 'global' ID)"
    }
  }
}
